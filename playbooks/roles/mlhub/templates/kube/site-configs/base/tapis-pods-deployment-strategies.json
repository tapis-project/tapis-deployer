{
    "platform": "tapis-pods",
    "description": "A set of strategies for deploying models to the Tapis K8s cluster with Tapis Pods",
    "strategies": [
        {
            "name": "Pods",
            "description": "Deploys a model as an HTTP server in Pods",
            "use_rule_sets": [
                "FlexServerDeployerCompatible",
                "VisiblePublic"
            ],
            "use_parameter_set": "Pods"
        }
    ],
    "rule_sets": [
        {
            "name": "FlexServerDeployerCompatible",
            "rules": [
                {
                    "field_path": [
                        "libraries"
                    ],
                    "operator": "Contains",
                    "value": "transformers"
                },
                {
                    "field_path": [
                        "task_types"
                    ],
                    "operator": "AnyIn",
                    "value": [
                        "TextGeneration"
                    ]
                }
            ]
        },
        {
            "name": "VisiblePublic",
            "rules": [
                {
                    "field_path": [
                        "canonical",
                        "gated"
                    ],
                    "operator": "Eq",
                    "value": false
                },
                {
                    "field_path": [
                        "canonical",
                        "private"
                    ],
                    "operator": "Eq",
                    "value": false
                }
            ]
        }
    ],
    "parameter_sets": [
        {
            "name": "Pods",
            "parameters": [
                {
                    "name": "backend",
                    "type": "string",
                    "required": false,
                    "default": "transformers",
                    "choices": [
                        "transformers"
                    ]
                }
            ]
        }
    ]
}