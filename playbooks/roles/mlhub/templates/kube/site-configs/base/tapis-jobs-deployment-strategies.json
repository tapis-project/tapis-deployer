{
    "platform": "tapis-jobs",
    "description": "A set of strategies for deploying models to cloud and HPC systems with Tapis",
    "strategies": [
        {
            "name": "Stampede3",
            "description": "Deploys a model as a Slurm job on the Stapmede3 HPC System at TACC",
            "use_rule_sets": [
                "FlexServerDeployerCompatible",
                "VisiblePublic"
            ],
            "use_parameter_set": "TapisJobs"
        },
        {
            "name": "Frontera",
            "description": "Deploys a model as a Slurm job on the Frontera HPC System at TACC",
            "use_rule_sets": [
                "FlexServerDeployerCompatible",
                "VisiblePublic"
            ],
            "use_parameter_set": "TapisJobs"
        },
        {
            "name": "LoneStar6",
            "description": "Deploys a model as a Slurm job on the LoneStar6 HPC System at TACC",
            "use_rule_sets": [
                "FlexServerDeployerCompatible",
                "VisiblePublic"
            ],
            "use_parameter_set": "TapisJobs"
        },
        {
            "name": "Vista",
            "description": "Deploys a model as a Slurm job on the Vista HPC System at TACC",
            "use_rule_sets": [
                "FlexServerDeployerCompatible",
                "VisiblePublic"
            ],
            "use_parameter_set": "TapisJobs"
        },
        {
            "name": "BYO System",
            "description": "Deploys a model to a user-owned system",
            "use_rule_sets": [
                "FlexServerDeployerCompatible",
                "VisiblePublic"
            ],
            "use_parameter_set": "UserSystem"
        }
    ],
    "rule_sets": [
        {
            "name": "FlexServerDeployerCompatible",
            "rules": [
                {
                    "field_path": [
                        "libraries"
                    ],
                    "operator": "Contains",
                    "value": "transformers"
                },
                {
                    "field_path": [
                        "task_types"
                    ],
                    "operator": "AnyIn",
                    "value": [
                        "TextGeneration"
                    ]
                }
            ]
        },
        {
            "name": "VisiblePublic",
            "rules": [
                {
                    "field_path": [
                        "canonical",
                        "gated"
                    ],
                    "operator": "Eq",
                    "value": false
                },
                {
                    "field_path": [
                        "canonical",
                        "private"
                    ],
                    "operator": "Eq",
                    "value": false
                }
            ]
        }
    ],
    "parameter_sets": [
        {
            "name": "TapisJobs",
            "parameters": [
                {
                    "name": "allocation",
                    "type": "string",
                    "required": false
                },
                {
                    "name": "backend",
                    "type": "string",
                    "required": false,
                    "default": "transformers",
                    "choices": [
                        "transformers"
                    ]
                }
            ]
        },
        {
            "name": "UserSystem",
            "parameters": [
                {
                    "name": "allocation",
                    "type": "string",
                    "required": false
                },
                {
                    "name": "system_id",
                    "type": "string",
                    "required": true
                },
                {
                    "name": "jobParameterSet",
                    "type": "object",
                    "required": false
                },
                {
                    "name": "backend",
                    "type": "string",
                    "required": false,
                    "default": "transformers",
                    "choices": [
                        "transformers"
                    ]
                }
            ]
        },
        {
            "name": "FlexServDeployer",
            "parameters": [
                {
                    "name": "allocation",
                    "type": "string",
                    "required": false
                },
                {
                    "name": "backend",
                    "type": "string",
                    "required": false,
                    "default": "transformers",
                    "choices": [
                        "transformers"
                    ]
                }
            ]
        }
    ]
}